{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/_expo/(.*)",
      "dest": "/_expo/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/fonts/(.*)",
      "dest": "/fonts/$1"
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/favicon\\.png",
      "dest": "/favicon.png"
    },
    {
      "src": "/apple-touch-icon\\.png",
      "dest": "/apple-touch-icon.png"
    },
    {
      "src": "/icon\\.png",
      "dest": "/icon.png"
    },
    {
      "src": "/icon-192\\.png",
      "dest": "/icon-192.png"
    },
    {
      "src": "/icon-512\\.png",
      "dest": "/icon-512.png"
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
